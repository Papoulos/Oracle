# --- Configuration Ollama (Défaut) ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3

EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- Exemple Configuration llama-cpp (API OpenAI) ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=your-model-name
#
# EMBEDDING_PROVIDER=openai
# EMBEDDING_BASE_URL=http://localhost:8080/v1
# EMBEDDING_MODEL=your-model-name

# --- Configuration spécifique par agent (optionnel) ---
CHARACTER_MODEL=gemma3
CHARACTER_TEMP=0.7

NARRATOR_MODEL=gemma3
NARRATOR_TEMP=0.8

ORCHESTRATOR_MODEL=gemma3
ORCHESTRATOR_TEMP=0.5

# --- Chemins et VectorDB ---
CHROMA_PATH=./chroma_db
CORE_DATA_PATH=./data/core
SCENARIO_DATA_PATH=./data/scenario
